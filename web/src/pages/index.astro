---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/react/Hero.tsx';
import LogoMarquee from '../components/react/LogoMarquee.tsx';
import AuditSection from '../components/react/AuditSection.tsx';
import FAQSection from '../components/react/FAQSection.tsx';
import TeamSection from '../components/react/TeamSection.tsx';
import CTASection from '../components/react/CTASection.tsx';
import GBPSection from '../components/react/GBPSection.tsx';
import HeroSplitBlock from '../components/react/HeroSplitBlock.tsx';
import HeroBackground from '../components/react/HeroBackground.tsx';
import GBPBackground from '../components/react/GBPBackground.tsx';
import HeroLottie from '../components/react/HeroLottie.tsx';
import SEOSection from '../components/react/SEOSection.tsx';
import MetaAdsSection from '../components/react/MetaAdsSection.tsx';
import Header from '../components/Header.astro';
---

<Layout hideHeader={true}>
  <style is:inline>
    /* ── Fullpage scroll snap ───────────────────────────────────── */
    html {
      scroll-snap-type: y proximity;
      overflow-y: scroll;
      height: 100%;
    }
    body {
      height: 100%;
    }
    .snap-block {
      scroll-snap-align: start;
      scroll-snap-stop: normal;
      height: 100vh;
      height: 100dvh;
      overflow: hidden;
      transform: translateZ(0);
      will-change: transform;
    }
    /* На мобильных (< 768px) отключаем snap и фиксированную высоту */
    @media (max-width: 767px) {
      html {
        scroll-snap-type: none;
      }
      .snap-block {
        height: auto !important;
        overflow: visible !important;
      }
    }

    /* ── Hero header override ───────────────────────────────────── */
    .site-header {
      background: transparent !important;
      backdrop-filter: none !important;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important;
    }
  </style>

  <!-- Block 1: Hero -->
  <div class="snap-block relative w-full" style="background:#ebedff">
    <HeroBackground client:load />

    <div class="relative z-20 w-full">
      <Header />
    </div>

    <section class="relative z-10 pt-16 pb-0 lg:pt-20 h-full flex flex-col">
      <div class="container relative flex-1 flex items-center">
        <div class="grid items-center gap-10 lg:grid-cols-2 w-full py-4">
          <Hero client:load />
          <div class="max-lg:!hidden flex h-[420px] items-center justify-center overflow-hidden relative">
            <HeroLottie client:load />
          </div>
        </div>
      </div>
      <div class="relative z-10 border-t border-white/20 py-4 flex-shrink-0">
        <div class="container">
          <LogoMarquee client:load />
        </div>
      </div>
    </section>
  </div>

  <!-- Block 2: Hero Split — GBP card + 20 platforms -->
  <div class="snap-block relative w-full" style="background:#d4ffee; overflow-y:auto; -webkit-overflow-scrolling:touch">
    <GBPBackground client:load />
    <section class="relative z-10 pt-16 pb-8 lg:pt-20 min-h-full flex flex-col justify-center">
      <div class="container relative py-4">
        <HeroSplitBlock client:load />
      </div>
    </section>
  </div>

  <!-- Block 3: SEO продвижение в Google -->
  <SEOSection client:load />

  <!-- Block 4: Сайты для бизнеса -->
  <GBPSection client:load />

  <!-- Block 5: Meta Ads — таргетированная реклама -->
  <MetaAdsSection client:load />

  <!-- Block 6: Free Audit -->
  <AuditSection client:visible />

  <!-- Block 6: FAQ -->
  <FAQSection client:visible />

  <!-- Block 7: Team -->
  <section id="team" class="snap-block relative overflow-hidden flex items-center bg-white">
    <div class="container w-full">
      <TeamSection client:visible />
    </div>
  </section>

  <!-- Block 9: Final CTA (scroll-snap-stop: normal allows scrolling to footer) -->
  <div class="snap-block" style="scroll-snap-stop: normal;">
    <CTASection client:visible />
  </div>
</Layout>
