---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/react/Hero.tsx';
import ServicesSection from '../components/react/ServicesSection.tsx';
import LogoMarquee from '../components/react/LogoMarquee.tsx';
import AuditSpotlight from '../components/react/AuditSpotlight.tsx';
import PricingSection from '../components/react/PricingSection.tsx';
import FAQSection from '../components/react/FAQSection.tsx';
import TeamSection from '../components/react/TeamSection.tsx';
import CTASection from '../components/react/CTASection.tsx';
import GBPSection from '../components/react/GBPSection.tsx';
import HeroSplitBlock from '../components/react/HeroSplitBlock.tsx';
import HeroBackground from '../components/react/HeroBackground.tsx';
import GBPBackground from '../components/react/GBPBackground.tsx';
import HeroLottie from '../components/react/HeroLottie.tsx';
import SEOSection from '../components/react/SEOSection.tsx';
import Header from '../components/Header.astro';
---

<Layout hideHeader={true}>
  <style is:inline>
    /* ── Fullpage scroll snap ───────────────────────────────────── */
    html {
      scroll-snap-type: y mandatory;
      overflow-y: scroll;
      height: 100%;
    }
    body {
      height: 100%;
    }
    .snap-block {
      scroll-snap-align: start;
      scroll-snap-stop: always;
      height: 100vh;
      overflow: hidden;
      /* Force a GPU compositing layer so WebGL canvases render
         continuously even when the block is offscreen */
      transform: translateZ(0);
      will-change: transform;
    }

    /* ── Hero header override ───────────────────────────────────── */
    .site-header {
      background: transparent !important;
      backdrop-filter: none !important;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important;
    }
  </style>

  <!-- Block 1: Hero -->
  <div class="snap-block relative w-full" style="background:#ebedff">
    <HeroBackground client:load />

    <div class="relative z-20 w-full">
      <Header />
    </div>

    <section class="relative z-10 pt-16 pb-8 lg:pt-20 h-full flex flex-col justify-center">
      <div class="container relative">
        <div class="grid items-center gap-10 lg:grid-cols-2">
          <Hero client:load />
          <div class="max-lg:!hidden flex h-[420px] items-center justify-center overflow-hidden relative">
            <HeroLottie client:load />
          </div>
        </div>
      </div>
      <div class="relative z-10 border-t border-white/20 mt-8 py-4">
        <div class="container">
          <LogoMarquee client:load />
        </div>
      </div>
    </section>
  </div>

  <!-- Block 2: Hero Split — GBP card + 20 platforms -->
  <div class="snap-block relative w-full" style="background:#d4ffee; overflow-y:auto">
    <GBPBackground client:load />
    <section class="relative z-10 pt-16 pb-8 lg:pt-20 h-full flex flex-col justify-center">
      <div class="container relative">
        <HeroSplitBlock client:load />
      </div>
    </section>
  </div>

  <!-- Block 3: GBP gradient (сайты для бизнеса) -->
  <GBPSection client:load />

  <!-- Block 4: SEO продвижение в Google -->
  <SEOSection client:load />

  <!-- Block 5: Services -->
  <section id="services" class="snap-block relative overflow-hidden flex items-center">
    <div class="container w-full">
      <ServicesSection client:visible />
    </div>
  </section>

  <!-- Block 4: Video Audit Spotlight -->
  <section class="snap-block relative overflow-hidden flex items-center">
    <div class="container w-full">
      <AuditSpotlight client:visible />
    </div>
  </section>

  <!-- Block 5: Pricing -->
  <section id="pricing" class="snap-block relative overflow-hidden flex items-center">
    <div class="container w-full">
      <PricingSection client:visible />
    </div>
  </section>

  <!-- Block 6: FAQ -->
  <section class="snap-block relative overflow-hidden flex items-center bg-surface">
    <div class="container w-full">
      <FAQSection client:visible />
    </div>
  </section>

  <!-- Block 7: Team -->
  <section id="team" class="snap-block relative overflow-hidden flex items-center bg-white">
    <div class="container w-full">
      <TeamSection client:visible />
    </div>
  </section>

  <!-- Block 8: Final CTA -->
  <div class="snap-block">
    <CTASection client:visible />
  </div>
</Layout>
